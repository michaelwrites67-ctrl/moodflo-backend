# OpenAI API key used for flow suggestions and meeting summaries.
OPENAI_API_KEY=your_openai_api_key

# OpenAI model used for structured JSON responses.
OPENAI_MODEL=gpt-5.4-nano

# Max seconds to wait for OpenAI before fallback output is used.
OPENAI_TIMEOUT_SECONDS=25

# Backend bind host.
HOST=0.0.0.0

# Backend port used by extension API/WebSocket calls.
PORT=8000

# Development mode switch (reload/debug behavior).
DEBUG=True
